import { Button, LineEdit, StandardTableView } from "std-widgets.slint";

export struct TransferItem {
    hash: string,
    name: string,
    state: string,
    progress: float,
    progress-text: string,
    size-text: string,
    speed-text: string,
    sources-text: string,
    category: string,
    detail: string,
}

export struct UploadItem {
    client-id: string,
    user: string,
    state: string,
    file: string,
    speed-text: string,
    uploaded-text: string,
    ratio: float,
    detail: string,
}

export struct ServerItem {
    name: string,
    endpoint-id: string,
    endpoint: string,
    status: string,
    users-text: string,
    files-text: string,
    ping-text: string,
    priority: string,
    failed-text: string,
    current: bool,
    detail: string,
}

export struct SharedFileItem {
    hash: string,
    name: string,
    directory: string,
    size-text: string,
    requests-text: string,
    transferred-text: string,
    priority: string,
    rating-text: string,
    demand-ratio: float,
    detail: string,
}

export struct LogItem {
    timestamp: string,
    level: string,
    message: string,
}

export struct SearchResultItem {
    search-id: string,
    hash: string,
    name: string,
    size-text: string,
    sources-text: string,
    complete-sources-text: string,
    file-type: string,
    method: string,
    known-type: string,
    detail: string,
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked;

    height: 28px;
    width: max(92px, label.preferred-width + 24px);
    background: selected ? #1f2937 : transparent;
    border-color: selected ? #1f2937 : #cbd5e1;
    border-width: selected ? 1px : 0px;
    border-radius: 3px;

    label := Text {
        x: 12px;
        y: 0px;
        height: parent.height;
        text: root.text;
        color: root.selected ? #ffffff : #334155;
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component StatusText inherits Text {
    in property <string> value;
    in property <length> block-width;

    text: value;
    color: #334155;
    font-size: 12px;
    height: 24px;
    width: block-width;
    vertical-alignment: center;
    overflow: elide;
}

component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> detail;

    background: #ffffff;

    VerticalLayout {
        padding: 28px;
        spacing: 6px;
        alignment: start;

        Text {
            text: root.title;
            color: #111827;
            font-size: 15px;
            font-weight: 700;
        }
        Text {
            text: root.detail;
            color: #64748b;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}

export component MainWindow inherits Window {
    in-out property <string> base-url;
    in-out property <string> api-key;
    in-out property <string> connection-state;
    in-out property <string> lifecycle-line;
    in-out property <string> network-line;
    in-out property <string> speed-line;
    in-out property <string> counts-line;
    in-out property <string> error-message;
    in-out property <string> transfer-summary;
    in-out property <string> upload-summary;
    in-out property <string> server-summary;
    in-out property <string> shared-summary;
    in-out property <string> search-query;
    in-out property <string> search-method;
    in-out property <string> search-type;
    in-out property <string> search-status-line;
    in-out property <[TransferItem]> transfers;
    in-out property <[SearchResultItem]> search-results;
    in-out property <[UploadItem]> uploads;
    in-out property <[UploadItem]> queued-uploads;
    in-out property <[ServerItem]> servers;
    in-out property <[SharedFileItem]> shared-files;
    in-out property <[LogItem]> logs;
    in-out property <[TableColumn]> transfer-columns;
    in-out property <[TableColumn]> search-result-columns;
    in-out property <[TableColumn]> server-columns;
    in-out property <[TableColumn]> shared-file-columns;
    in-out property <[TableColumn]> upload-columns;
    in-out property <[TableColumn]> queued-client-columns;
    in-out property <[TableColumn]> log-columns;
    in-out property <[[StandardListViewItem]]> transfer-rows;
    in-out property <[[StandardListViewItem]]> search-result-rows;
    in-out property <[[StandardListViewItem]]> server-rows;
    in-out property <[[StandardListViewItem]]> shared-file-rows;
    in-out property <[[StandardListViewItem]]> upload-rows;
    in-out property <[[StandardListViewItem]]> queued-client-rows;
    in-out property <[[StandardListViewItem]]> log-rows;
    in-out property <int> selected-tab;
    in-out property <string> selected-kind;
    in-out property <string> selected-id;
    in-out property <string> selected-search-id;
    in-out property <string> inspector-title;
    in-out property <string> inspector-detail;
    in-out property <bool> is-refreshing;

    callback connect-requested(string, string);
    callback refresh-requested();
    callback search-requested(string, string, string);
    callback search-refresh-requested();
    callback search-download-requested(string, string, bool);
    callback transfer-action-requested(string, string);
    callback server-action-requested(string);

    title: "eMuleBB Rust UI";
    preferred-width: 1240px;
    preferred-height: 820px;
    min-width: 980px;
    min-height: 620px;
    background: #f4f6f9;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        Rectangle {
            height: 44px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 8px;

                Text {
                    text: "eMuleBB Rust";
                    font-size: 16px;
                    font-weight: 700;
                    color: #111827;
                    vertical-alignment: center;
                    min-width: 128px;
                }

                LineEdit {
                    text <=> root.base-url;
                    placeholder-text: "REST base URL";
                    min-width: 340px;
                }

                LineEdit {
                    text <=> root.api-key;
                    placeholder-text: "API key";
                    min-width: 150px;
                }

                Button {
                    text: root.is-refreshing ? "Working" : "Connect";
                    enabled: !root.is-refreshing;
                    clicked => { root.connect-requested(root.base-url, root.api-key); }
                }

                Button {
                    text: "Refresh";
                    enabled: !root.is-refreshing;
                    clicked => { root.refresh-requested(); }
                }

                Text {
                    text: root.connection-state;
                    color: root.connection-state == "Connected" ? #047857 : #9a3412;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            height: 34px;
            background: #ffffff;
            border-color: #d7dee8;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 3px;
                padding-bottom: 3px;
                spacing: 6px;
                TabButton { text: "Kad"; selected: root.selected-tab == 0; clicked => { root.selected-tab = 0; } }
                TabButton { text: "Servers"; selected: root.selected-tab == 1; clicked => { root.selected-tab = 1; } }
                TabButton { text: "Search"; selected: root.selected-tab == 2; clicked => { root.selected-tab = 2; } }
                TabButton { text: "Downloads"; selected: root.selected-tab == 3; clicked => { root.selected-tab = 3; } }
                TabButton { text: "Uploads"; selected: root.selected-tab == 4; clicked => { root.selected-tab = 4; } }
                TabButton { text: "Queued Clients"; selected: root.selected-tab == 5; clicked => { root.selected-tab = 5; } }
                TabButton { text: "Known Clients"; selected: root.selected-tab == 6; clicked => { root.selected-tab = 6; } }
                TabButton { text: "Shared Files"; selected: root.selected-tab == 7; clicked => { root.selected-tab = 7; } }
                TabButton { text: "Logs"; selected: root.selected-tab == 8; clicked => { root.selected-tab = 8; } }
            }
        }

        Rectangle {
            height: 28px;
            background: root.error-message == "" ? #f8fafc : #fff7ed;
            border-color: root.error-message == "" ? #d7dee8 : #fdba74;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 12px;
                StatusText { value: root.lifecycle-line; block-width: 160px; }
                StatusText { value: root.transfer-summary; block-width: 150px; }
                StatusText { value: root.server-summary; block-width: 108px; }
                StatusText { value: root.shared-summary; block-width: 108px; }
                StatusText { value: root.upload-summary; block-width: 130px; }
                StatusText { value: root.speed-line; block-width: 180px; }
                Text {
                    text: root.error-message == "" ? root.network-line : root.error-message;
                    color: root.error-message == "" ? #64748b : #9a3412;
                    font-size: 12px;
                    height: 24px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            if root.selected-tab == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "Kad";
                detail: root.network-line;
            }

            if root.selected-tab == 1 && root.server-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.server-columns;
                rows: root.server-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.servers.length {
                        root.selected-kind = "server";
                        root.selected-id = root.servers[row].endpoint-id;
                        root.inspector-title = root.servers[row].name;
                        root.inspector-detail = root.servers[row].detail;
                    }
                }
            }

            if root.selected-tab == 1 && root.server-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No servers";
                detail: "The REST snapshot did not return any known servers.";
            }

            if root.selected-tab == 2 : Rectangle {
                width: parent.width;
                height: parent.height;
                background: #ffffff;

                VerticalLayout {
                    padding: 8px;
                    spacing: 8px;

                    Rectangle {
                        height: 38px;
                        background: #f8fafc;
                        border-color: #d7dee8;
                        border-width: 1px;
                        border-radius: 3px;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            spacing: 6px;

                            LineEdit {
                                text <=> root.search-query;
                                placeholder-text: "Search query";
                                min-width: 360px;
                            }
                            LineEdit {
                                text <=> root.search-method;
                                placeholder-text: "automatic, global, server, kad";
                                min-width: 150px;
                            }
                            LineEdit {
                                text <=> root.search-type;
                                placeholder-text: "type";
                                min-width: 92px;
                            }
                            Button {
                                text: "Start";
                                enabled: !root.is-refreshing;
                                clicked => { root.search-requested(root.search-query, root.search-method, root.search-type); }
                            }
                            Button {
                                text: "Poll";
                                enabled: !root.is-refreshing;
                                clicked => { root.search-refresh-requested(); }
                            }
                            Text {
                                text: root.search-status-line;
                                color: #334155;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }

                    if root.search-result-rows.length > 0 : StandardTableView {
                        columns <=> root.search-result-columns;
                        rows: root.search-result-rows;
                        current-row-changed(row) => {
                            if row >= 0 && row < root.search-results.length {
                                root.selected-kind = "search-result";
                                root.selected-id = root.search-results[row].hash;
                                root.selected-search-id = root.search-results[row].search-id;
                                root.inspector-title = root.search-results[row].name;
                                root.inspector-detail = root.search-results[row].detail;
                            }
                        }
                    }

                    if root.search-result-rows.length == 0 : EmptyState {
                        title: "No search results";
                        detail: root.search-status-line == "" ? "Start a search to populate this table." : root.search-status-line;
                    }
                }
            }

            if root.selected-tab == 3 && root.transfer-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.transfer-columns;
                rows: root.transfer-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.transfers.length {
                        root.selected-kind = "transfer";
                        root.selected-id = root.transfers[row].hash;
                        root.inspector-title = root.transfers[row].name;
                        root.inspector-detail = root.transfers[row].detail;
                    }
                }
            }

            if root.selected-tab == 3 && root.transfer-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No downloads";
                detail: "The REST snapshot currently reports zero download transfers. Uploads and queued clients are shown in their own tabs.";
            }

            if root.selected-tab == 4 && root.upload-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.upload-columns;
                rows: root.upload-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.uploads.length {
                        root.selected-kind = "upload";
                        root.selected-id = root.uploads[row].client-id;
                        root.inspector-title = root.uploads[row].user;
                        root.inspector-detail = root.uploads[row].detail;
                    }
                }
            }

            if root.selected-tab == 4 && root.upload-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No uploads";
                detail: "The REST snapshot currently reports no active uploads.";
            }

            if root.selected-tab == 5 && root.queued-client-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.queued-client-columns;
                rows: root.queued-client-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.queued-uploads.length {
                        root.selected-kind = "upload";
                        root.selected-id = root.queued-uploads[row].client-id;
                        root.inspector-title = root.queued-uploads[row].user;
                        root.inspector-detail = root.queued-uploads[row].detail;
                    }
                }
            }

            if root.selected-tab == 5 && root.queued-client-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No queued clients";
                detail: "The REST snapshot currently reports no clients waiting for upload slots.";
            }

            if root.selected-tab == 6 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "Known Clients";
                detail: "Known clients are reserved for the peer/client registry. The current REST snapshot does not expose a known-client table yet.";
            }

            if root.selected-tab == 7 && root.shared-file-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.shared-file-columns;
                rows: root.shared-file-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.shared-files.length {
                        root.selected-kind = "shared";
                        root.selected-id = root.shared-files[row].hash;
                        root.inspector-title = root.shared-files[row].name;
                        root.inspector-detail = root.shared-files[row].detail;
                    }
                }
            }

            if root.selected-tab == 7 && root.shared-file-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No shared files";
                detail: "The REST snapshot did not return shared files.";
            }

            if root.selected-tab == 8 && root.log-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.log-columns;
                rows: root.log-rows;
            }

            if root.selected-tab == 8 && root.log-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No logs";
                detail: "The REST snapshot did not return log entries.";
            }
        }

        Rectangle {
            height: 104px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;
                    Text {
                        text: root.inspector-title == "" ? "Inspector" : root.inspector-title;
                        color: #111827;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    if root.selected-kind == "transfer" : Button { text: "Pause"; clicked => { root.transfer-action-requested(root.selected-id, "pause"); } }
                    if root.selected-kind == "transfer" : Button { text: "Resume"; clicked => { root.transfer-action-requested(root.selected-id, "resume"); } }
                    if root.selected-kind == "transfer" : Button { text: "Stop"; clicked => { root.transfer-action-requested(root.selected-id, "stop"); } }
                    if root.selected-kind == "transfer" : Button { text: "Recheck"; clicked => { root.transfer-action-requested(root.selected-id, "recheck"); } }
                    if root.selected-kind == "transfer" : Button { text: "Preview"; clicked => { root.transfer-action-requested(root.selected-id, "preview"); } }
                    if root.selected-kind == "search-result" : Button { text: "Download"; clicked => { root.search-download-requested(root.selected-search-id, root.selected-id, false); } }
                    if root.selected-kind == "search-result" : Button { text: "Download Paused"; clicked => { root.search-download-requested(root.selected-search-id, root.selected-id, true); } }
                    if root.selected-kind == "server" : Button { text: "Connect"; clicked => { root.server-action-requested("connect"); } }
                    if root.selected-kind == "server" : Button { text: "Disconnect"; clicked => { root.server-action-requested("disconnect"); } }
                }
                Text {
                    text: root.inspector-detail == "" ? root.counts-line : root.inspector-detail;
                    color: #334155;
                    font-size: 12px;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }
        }
    }
}
