import { Button, LineEdit, StandardTableView } from "std-widgets.slint";

export struct TransferItem {
    hash: string,
    name: string,
    state: string,
    progress: float,
    progress-text: string,
    size-text: string,
    speed-text: string,
    sources-text: string,
    category: string,
    detail: string,
}

export struct UploadItem {
    client-id: string,
    user: string,
    state: string,
    file: string,
    speed-text: string,
    uploaded-text: string,
    ratio: float,
    detail: string,
}

export struct ServerItem {
    name: string,
    endpoint-id: string,
    endpoint: string,
    status: string,
    users-text: string,
    files-text: string,
    ping-text: string,
    priority: string,
    failed-text: string,
    current: bool,
    detail: string,
}

export struct SharedFileItem {
    hash: string,
    name: string,
    directory: string,
    size-text: string,
    requests-text: string,
    transferred-text: string,
    priority: string,
    rating-text: string,
    demand-ratio: float,
    detail: string,
}

export struct LogItem {
    timestamp: string,
    level: string,
    message: string,
}

export struct SpeedSample {
    down: float,
    up: float,
}

component SparkBars inherits Rectangle {
    in property <[SpeedSample]> samples;

    background: transparent;
    height: 26px;

    HorizontalLayout {
        height: 26px;
        padding-left: 4px;
        padding-right: 4px;
        spacing: 2px;
        alignment: end;

        for sample in root.samples : Rectangle {
            width: 6px;
            height: 20px;
            background: transparent;

            Rectangle {
                x: 0px;
                y: 20px - self.height;
                width: 2px;
                height: 20px * sample.down;
                background: #2563eb;
                border-radius: 1px;
            }
            Rectangle {
                x: 3px;
                y: 20px - self.height;
                width: 2px;
                height: 20px * sample.up;
                background: #16a34a;
                border-radius: 1px;
            }
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked;

    height: 28px;
    width: max(92px, label.preferred-width + 24px);
    background: selected ? #1f2937 : transparent;
    border-color: selected ? #1f2937 : #cbd5e1;
    border-width: selected ? 1px : 0px;
    border-radius: 3px;

    label := Text {
        x: 12px;
        y: 0px;
        height: parent.height;
        text: root.text;
        color: root.selected ? #ffffff : #334155;
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component StatusText inherits Text {
    in property <string> value;
    in property <length> block-width;

    text: value;
    color: #334155;
    font-size: 12px;
    height: 24px;
    width: block-width;
    vertical-alignment: center;
    overflow: elide;
}

component EmptyState inherits Rectangle {
    in property <string> title;
    in property <string> detail;

    background: #ffffff;

    VerticalLayout {
        padding: 28px;
        spacing: 6px;
        alignment: start;

        Text {
            text: root.title;
            color: #111827;
            font-size: 15px;
            font-weight: 700;
        }
        Text {
            text: root.detail;
            color: #64748b;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}

export component MainWindow inherits Window {
    in-out property <string> base-url;
    in-out property <string> api-key;
    in-out property <string> connection-state;
    in-out property <string> lifecycle-line;
    in-out property <string> network-line;
    in-out property <string> speed-line;
    in-out property <string> counts-line;
    in-out property <string> error-message;
    in-out property <string> transfer-summary;
    in-out property <string> upload-summary;
    in-out property <string> server-summary;
    in-out property <string> shared-summary;
    in-out property <[TransferItem]> transfers;
    in-out property <[UploadItem]> uploads;
    in-out property <[ServerItem]> servers;
    in-out property <[SharedFileItem]> shared-files;
    in-out property <[LogItem]> logs;
    in-out property <[SpeedSample]> speed-samples;
    in-out property <[TableColumn]> transfer-columns;
    in-out property <[TableColumn]> server-columns;
    in-out property <[TableColumn]> shared-file-columns;
    in-out property <[TableColumn]> upload-columns;
    in-out property <[TableColumn]> log-columns;
    in-out property <[[StandardListViewItem]]> transfer-rows;
    in-out property <[[StandardListViewItem]]> server-rows;
    in-out property <[[StandardListViewItem]]> shared-file-rows;
    in-out property <[[StandardListViewItem]]> upload-rows;
    in-out property <[[StandardListViewItem]]> log-rows;
    in-out property <int> selected-tab;
    in-out property <string> selected-kind;
    in-out property <string> selected-id;
    in-out property <string> inspector-title;
    in-out property <string> inspector-detail;
    in-out property <bool> is-refreshing;

    callback connect-requested(string, string);
    callback refresh-requested();
    callback transfer-action-requested(string, string);
    callback server-action-requested(string);

    title: "eMuleBB Rust UI";
    preferred-width: 1240px;
    preferred-height: 820px;
    min-width: 980px;
    min-height: 620px;
    background: #f4f6f9;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        Rectangle {
            height: 44px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 5px;
                padding-bottom: 5px;
                spacing: 8px;

                Text {
                    text: "eMuleBB Rust";
                    font-size: 16px;
                    font-weight: 700;
                    color: #111827;
                    vertical-alignment: center;
                    min-width: 128px;
                }

                LineEdit {
                    text <=> root.base-url;
                    placeholder-text: "REST base URL";
                    min-width: 340px;
                }

                LineEdit {
                    text <=> root.api-key;
                    placeholder-text: "API key";
                    min-width: 150px;
                }

                Button {
                    text: root.is-refreshing ? "Working" : "Connect";
                    enabled: !root.is-refreshing;
                    clicked => { root.connect-requested(root.base-url, root.api-key); }
                }

                Button {
                    text: "Refresh";
                    enabled: !root.is-refreshing;
                    clicked => { root.refresh-requested(); }
                }

                Text {
                    text: root.connection-state;
                    color: root.connection-state == "Connected" ? #047857 : #9a3412;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            height: 34px;
            background: #ffffff;
            border-color: #d7dee8;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 3px;
                padding-bottom: 3px;
                spacing: 6px;
                TabButton { text: "Transfers"; selected: root.selected-tab == 0; clicked => { root.selected-tab = 0; } }
                TabButton { text: "Servers"; selected: root.selected-tab == 1; clicked => { root.selected-tab = 1; } }
                TabButton { text: "Shared Files"; selected: root.selected-tab == 2; clicked => { root.selected-tab = 2; } }
                TabButton { text: "Uploads"; selected: root.selected-tab == 3; clicked => { root.selected-tab = 3; } }
                TabButton { text: "Logs"; selected: root.selected-tab == 4; clicked => { root.selected-tab = 4; } }
                Text {
                    text: root.speed-line;
                    color: #166534;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    overflow: elide;
                }
                SparkBars { samples: root.speed-samples; width: 220px; }
            }
        }

        Rectangle {
            height: 28px;
            background: root.error-message == "" ? #f8fafc : #fff7ed;
            border-color: root.error-message == "" ? #d7dee8 : #fdba74;
            border-width: 1px;
            border-radius: 3px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 12px;
                StatusText { value: root.lifecycle-line; block-width: 160px; }
                StatusText { value: root.transfer-summary; block-width: 150px; }
                StatusText { value: root.server-summary; block-width: 108px; }
                StatusText { value: root.shared-summary; block-width: 108px; }
                StatusText { value: root.upload-summary; block-width: 130px; }
                Text {
                    text: root.error-message == "" ? root.network-line : root.error-message;
                    color: root.error-message == "" ? #64748b : #9a3412;
                    font-size: 12px;
                    height: 24px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            if root.selected-tab == 0 && root.transfer-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.transfer-columns;
                rows: root.transfer-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.transfers.length {
                        root.selected-kind = "transfer";
                        root.selected-id = root.transfers[row].hash;
                        root.inspector-title = root.transfers[row].name;
                        root.inspector-detail = root.transfers[row].detail;
                    }
                }
            }

            if root.selected-tab == 0 && root.transfer-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No transfers";
                detail: "The REST snapshot currently reports zero download transfers. Servers, uploads, shared files, and logs may still have live data.";
            }

            if root.selected-tab == 1 && root.server-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.server-columns;
                rows: root.server-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.servers.length {
                        root.selected-kind = "server";
                        root.selected-id = root.servers[row].endpoint-id;
                        root.inspector-title = root.servers[row].name;
                        root.inspector-detail = root.servers[row].detail;
                    }
                }
            }

            if root.selected-tab == 1 && root.server-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No servers";
                detail: "The REST snapshot did not return any known servers.";
            }

            if root.selected-tab == 2 && root.shared-file-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.shared-file-columns;
                rows: root.shared-file-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.shared-files.length {
                        root.selected-kind = "shared";
                        root.selected-id = root.shared-files[row].hash;
                        root.inspector-title = root.shared-files[row].name;
                        root.inspector-detail = root.shared-files[row].detail;
                    }
                }
            }

            if root.selected-tab == 2 && root.shared-file-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No shared files";
                detail: "The REST snapshot did not return shared files.";
            }

            if root.selected-tab == 3 && root.upload-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.upload-columns;
                rows: root.upload-rows;
                current-row-changed(row) => {
                    if row >= 0 && row < root.uploads.length {
                        root.selected-kind = "upload";
                        root.selected-id = root.uploads[row].client-id;
                        root.inspector-title = root.uploads[row].user;
                        root.inspector-detail = root.uploads[row].detail;
                    }
                }
            }

            if root.selected-tab == 3 && root.upload-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No uploads";
                detail: "The REST snapshot currently reports no active or queued uploads.";
            }

            if root.selected-tab == 4 && root.log-rows.length > 0 : StandardTableView {
                width: parent.width;
                height: parent.height;
                columns <=> root.log-columns;
                rows: root.log-rows;
            }

            if root.selected-tab == 4 && root.log-rows.length == 0 : EmptyState {
                width: parent.width;
                height: parent.height;
                title: "No logs";
                detail: "The REST snapshot did not return log entries.";
            }
        }

        Rectangle {
            height: 104px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 3px;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;
                    Text {
                        text: root.inspector-title == "" ? "Inspector" : root.inspector-title;
                        color: #111827;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    if root.selected-kind == "transfer" : Button { text: "Pause"; clicked => { root.transfer-action-requested(root.selected-id, "pause"); } }
                    if root.selected-kind == "transfer" : Button { text: "Resume"; clicked => { root.transfer-action-requested(root.selected-id, "resume"); } }
                    if root.selected-kind == "transfer" : Button { text: "Stop"; clicked => { root.transfer-action-requested(root.selected-id, "stop"); } }
                    if root.selected-kind == "transfer" : Button { text: "Recheck"; clicked => { root.transfer-action-requested(root.selected-id, "recheck"); } }
                    if root.selected-kind == "transfer" : Button { text: "Preview"; clicked => { root.transfer-action-requested(root.selected-id, "preview"); } }
                    if root.selected-kind == "server" : Button { text: "Connect"; clicked => { root.server-action-requested("connect"); } }
                    if root.selected-kind == "server" : Button { text: "Disconnect"; clicked => { root.server-action-requested("disconnect"); } }
                }
                Text {
                    text: root.inspector-detail == "" ? root.counts-line : root.inspector-detail;
                    color: #334155;
                    font-size: 12px;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }
        }
    }
}
