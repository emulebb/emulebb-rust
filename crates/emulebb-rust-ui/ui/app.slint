component UploadRow inherits Rectangle {
    in property <UploadItem> item;
    in property <bool> selected-row;
    callback selected;

    height: 28px;
    background: selected-row ? #dbeafe : #ffffff;
    border-color: selected-row ? #93c5fd : #e5e7eb;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        DataCell { value: item.user; cell-width: 210px; }
        MutedCell { value: item.file; cell-width: 360px; }
        Rectangle {
            width: 96px;
            height: 28px;
            background: transparent;
            RowBadge { y: 5px; text: item.state; fill: #ecfdf5; ink: #047857; }
        }
        NumberCell { value: item.speed-text; cell-width: 86px; }
        NumberCell { value: item.uploaded-text; cell-width: 100px; }
        Rectangle {
            width: 124px;
            height: 28px;
            background: transparent;
            ProgressBar { x: 0px; y: 11px; width: 112px; value: item.ratio; fill: #16a34a; }
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.selected(); }
    }
}

component LogHeader inherits Rectangle {
    height: 26px;
    background: #eef2f7;
    border-color: #cbd5e1;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HeaderCell { label: "Time"; cell-width: 176px; }
        HeaderCell { label: "Level"; cell-width: 76px; }
        HeaderCell { label: "Message"; cell-width: 780px; }
    }
}

component LogRow inherits Rectangle {
    in property <LogItem> item;

    height: 28px;
    background: item.level == "error" ? #fef2f2 : item.level == "warning" ? #fffbeb : #ffffff;
    border-color: #e5e7eb;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        MutedCell { value: item.timestamp; cell-width: 176px; }
        DataCell { value: item.level; cell-width: 76px; }
        DataCell { value: item.message; cell-width: 780px; }
    }
}

export component MainWindow inherits Window {
    in-out property <string> base-url;
    in-out property <string> api-key;
    in-out property <string> connection-state;
    in-out property <string> lifecycle-line;
    in-out property <string> network-line;
    in-out property <string> speed-line;
    in-out property <string> counts-line;
    in-out property <string> error-message;
    in-out property <string> transfer-summary;
    in-out property <string> upload-summary;
    in-out property <string> server-summary;
    in-out property <string> shared-summary;
    in-out property <[TransferItem]> transfers;
    in-out property <[UploadItem]> uploads;
    in-out property <[ServerItem]> servers;
    in-out property <[SharedFileItem]> shared-files;
    in-out property <[LogItem]> logs;
    in-out property <[SpeedSample]> speed-samples;
    in-out property <int> selected-tab;
    in-out property <string> selected-kind;
    in-out property <string> selected-id;
    in-out property <string> inspector-title;
    in-out property <string> inspector-detail;
    in-out property <bool> is-refreshing;

    callback connect-requested(string, string);
    callback refresh-requested();
    callback transfer-action-requested(string, string);
    callback server-action-requested(string);

    title: "eMuleBB Rust UI";
    preferred-width: 1240px;
    preferred-height: 820px;
    min-width: 980px;
    min-height: 620px;
    background: #f5f7fb;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        Rectangle {
            height: 46px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 4px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 8px;

                Text {
                    text: "eMuleBB Rust";
                    font-size: 17px;
                    font-weight: 700;
                    color: #111827;
                    vertical-alignment: center;
                    min-width: 128px;
                }

                LineEdit {
                    text <=> root.base-url;
                    placeholder-text: "REST base URL";
                    min-width: 330px;
                }

                LineEdit {
                    text <=> root.api-key;
                    placeholder-text: "API key";
                    min-width: 150px;
                }

                Button {
                    text: root.is-refreshing ? "Working" : "Connect";
                    enabled: !root.is-refreshing;
                    clicked => { root.connect-requested(root.base-url, root.api-key); }
                }

                Button {
                    text: "Refresh";
                    enabled: !root.is-refreshing;
                    clicked => { root.refresh-requested(); }
                }

                Text {
                    text: root.connection-state;
                    color: root.connection-state == "Connected" ? #047857 : #9a3412;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
        }

        Rectangle {
            height: 34px;
            background: #ffffff;
            border-color: #d7dee8;
            border-width: 1px;
            border-radius: 4px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                TabButton { text: "Transfers"; selected: root.selected-tab == 0; clicked => { root.selected-tab = 0; } }
                TabButton { text: "Servers"; selected: root.selected-tab == 1; clicked => { root.selected-tab = 1; } }
                TabButton { text: "Shared Files"; selected: root.selected-tab == 2; clicked => { root.selected-tab = 2; } }
                TabButton { text: "Uploads"; selected: root.selected-tab == 3; clicked => { root.selected-tab = 3; } }
                TabButton { text: "Logs"; selected: root.selected-tab == 4; clicked => { root.selected-tab = 4; } }
                Text {
                    text: root.speed-line;
                    color: #166534;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
                SparkBars { samples: root.speed-samples; width: 220px; }
            }
        }

        Rectangle {
            height: 28px;
            background: root.error-message == "" ? #f8fafc : #fff7ed;
            border-color: root.error-message == "" ? #d7dee8 : #fdba74;
            border-width: 1px;
            border-radius: 4px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 12px;
                Text { text: root.lifecycle-line; color: #334155; font-size: 12px; vertical-alignment: center; min-width: 160px; overflow: elide; }
                Text { text: root.transfer-summary; color: #334155; font-size: 12px; vertical-alignment: center; min-width: 146px; overflow: elide; }
                Text { text: root.server-summary; color: #334155; font-size: 12px; vertical-alignment: center; min-width: 104px; overflow: elide; }
                Text { text: root.shared-summary; color: #334155; font-size: 12px; vertical-alignment: center; min-width: 104px; overflow: elide; }
                Text { text: root.upload-summary; color: #334155; font-size: 12px; vertical-alignment: center; min-width: 126px; overflow: elide; }
                Text {
                    text: root.error-message == "" ? root.network-line : root.error-message;
                    color: root.error-message == "" ? #64748b : #9a3412;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 4px;

            if root.selected-tab == 0 : VerticalLayout {
                width: parent.width;
                height: parent.height;
                TransferHeader {}
                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        for item in root.transfers : TransferRow {
                            item: item;
                            selected-row: root.selected-kind == "transfer" && root.selected-id == item.hash;
                            selected => {
                                root.selected-kind = "transfer";
                                root.selected-id = item.hash;
                                root.inspector-title = item.name;
                                root.inspector-detail = item.detail;
                            }
                        }
                    }
                }
            }

            if root.selected-tab == 1 : VerticalLayout {
                width: parent.width;
                height: parent.height;
                ServerHeader {}
                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        for item in root.servers : ServerRow {
                            item: item;
                            selected-row: root.selected-kind == "server" && root.selected-id == item.endpoint-id;
                            selected => {
                                root.selected-kind = "server";
                                root.selected-id = item.endpoint-id;
                                root.inspector-title = item.name;
                                root.inspector-detail = item.detail;
                            }
                        }
                    }
                }
            }

            if root.selected-tab == 2 : VerticalLayout {
                width: parent.width;
                height: parent.height;
                SharedFileHeader {}
                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        for item in root.shared-files : SharedFileRow {
                            item: item;
                            selected-row: root.selected-kind == "shared" && root.selected-id == item.hash;
                            selected => {
                                root.selected-kind = "shared";
                                root.selected-id = item.hash;
                                root.inspector-title = item.name;
                                root.inspector-detail = item.detail;
                            }
                        }
                    }
                }
            }

            if root.selected-tab == 3 : VerticalLayout {
                width: parent.width;
                height: parent.height;
                UploadHeader {}
                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        for item in root.uploads : UploadRow {
                            item: item;
                            selected-row: root.selected-kind == "upload" && root.selected-id == item.client-id;
                            selected => {
                                root.selected-kind = "upload";
                                root.selected-id = item.client-id;
                                root.inspector-title = item.user;
                                root.inspector-detail = item.detail;
                            }
                        }
                    }
                }
            }

            if root.selected-tab == 4 : VerticalLayout {
                width: parent.width;
                height: parent.height;
                LogHeader {}
                ScrollView {
                    VerticalLayout {
                        spacing: 0px;
                        for item in root.logs : LogRow { item: item; }
                    }
                }
            }
        }

        Rectangle {
            height: 94px;
            background: #ffffff;
            border-color: #cbd5e1;
            border-width: 1px;
            border-radius: 4px;

            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;
                    Text {
                        text: root.inspector-title == "" ? "Inspector" : root.inspector-title;
                        color: #111827;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    if root.selected-kind == "transfer" : Button { text: "Pause"; clicked => { root.transfer-action-requested(root.selected-id, "pause"); } }
                    if root.selected-kind == "transfer" : Button { text: "Resume"; clicked => { root.transfer-action-requested(root.selected-id, "resume"); } }
                    if root.selected-kind == "transfer" : Button { text: "Stop"; clicked => { root.transfer-action-requested(root.selected-id, "stop"); } }
                    if root.selected-kind == "transfer" : Button { text: "Recheck"; clicked => { root.transfer-action-requested(root.selected-id, "recheck"); } }
                    if root.selected-kind == "transfer" : Button { text: "Preview"; clicked => { root.transfer-action-requested(root.selected-id, "preview"); } }
                    if root.selected-kind == "server" : Button { text: "Connect"; clicked => { root.server-action-requested("connect"); } }
                    if root.selected-kind == "server" : Button { text: "Disconnect"; clicked => { root.server-action-requested("disconnect"); } }
                }
                Text {
                    text: root.inspector-detail == "" ? root.counts-line : root.inspector-detail;
                    color: #334155;
                    font-size: 12px;
                    wrap: word-wrap;
                    overflow: elide;
                }
            }
        }
    }
}
