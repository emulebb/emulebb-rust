import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export struct TransferItem {
    hash: string,
    name: string,
    state: string,
    progress: float,
    progress-text: string,
    size-text: string,
    speed-text: string,
    sources-text: string,
    category: string,
    detail: string,
}

export struct UploadItem {
    client-id: string,
    user: string,
    state: string,
    file: string,
    speed-text: string,
    uploaded-text: string,
    ratio: float,
    detail: string,
}

export struct ServerItem {
    name: string,
    endpoint-id: string,
    endpoint: string,
    status: string,
    users-text: string,
    files-text: string,
    ping-text: string,
    priority: string,
    failed-text: string,
    current: bool,
    detail: string,
}

export struct SharedFileItem {
    hash: string,
    name: string,
    directory: string,
    size-text: string,
    requests-text: string,
    transferred-text: string,
    priority: string,
    rating-text: string,
    demand-ratio: float,
    detail: string,
}

export struct LogItem {
    timestamp: string,
    level: string,
    message: string,
}

export struct SpeedSample {
    down: float,
    up: float,
}

component HeaderCell inherits Text {
    in property <string> label;
    in property <length> cell-width;

    text: label;
    width: cell-width;
    height: 26px;
    color: #334155;
    font-size: 11px;
    font-weight: 700;
    vertical-alignment: center;
    overflow: elide;
}

component DataCell inherits Text {
    in property <string> value;
    in property <length> cell-width;

    text: value;
    width: cell-width;
    height: 28px;
    color: #111827;
    font-size: 12px;
    vertical-alignment: center;
    overflow: elide;
}

component MutedCell inherits Text {
    in property <string> value;
    in property <length> cell-width;

    text: value;
    width: cell-width;
    height: 28px;
    color: #64748b;
    font-size: 12px;
    vertical-alignment: center;
    overflow: elide;
}

component NumberCell inherits Text {
    in property <string> value;
    in property <length> cell-width;

    text: value;
    width: cell-width;
    height: 28px;
    color: #334155;
    font-size: 12px;
    horizontal-alignment: right;
    vertical-alignment: center;
    overflow: elide;
}

component RowBadge inherits Rectangle {
    in property <string> text;
    in property <color> fill;
    in property <color> ink;

    height: 18px;
    width: max(58px, label.preferred-width + 14px);
    background: fill;
    border-radius: 3px;

    label := Text {
        x: 7px;
        y: 0px;
        height: parent.height;
        text: root.text;
        color: root.ink;
        font-size: 10px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

component ProgressBar inherits Rectangle {
    in property <float> value;
    in property <color> fill;

    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;

    Rectangle {
        width: parent.width * root.value;
        height: parent.height;
        background: root.fill;
        border-radius: 3px;
    }
}

component SparkBars inherits Rectangle {
    in property <[SpeedSample]> samples;

    background: transparent;
    height: 28px;

    HorizontalLayout {
        height: 28px;
        padding-left: 4px;
        padding-right: 4px;
        spacing: 2px;
        alignment: end;

        for sample in root.samples : Rectangle {
            width: 6px;
            height: 22px;
            background: transparent;

            Rectangle {
                x: 0px;
                y: 22px - self.height;
                width: 2px;
                height: 22px * sample.down;
                background: #2563eb;
                border-radius: 1px;
            }
            Rectangle {
                x: 3px;
                y: 22px - self.height;
                width: 2px;
                height: 22px * sample.up;
                background: #16a34a;
                border-radius: 1px;
            }
        }
    }
}

component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked;

    height: 30px;
    width: max(92px, label.preferred-width + 24px);
    background: selected ? #1f2937 : #ffffff;
    border-color: selected ? #1f2937 : #cbd5e1;
    border-width: 1px;
    border-radius: 4px;

    label := Text {
        x: 12px;
        y: 0px;
        height: parent.height;
        text: root.text;
        color: root.selected ? #ffffff : #334155;
        font-size: 12px;
        font-weight: root.selected ? 700 : 500;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.clicked(); }
    }
}

component TransferHeader inherits Rectangle {
    height: 26px;
    background: #eef2f7;
    border-color: #cbd5e1;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HeaderCell { label: "Name"; cell-width: 330px; }
        HeaderCell { label: "State"; cell-width: 82px; }
        HeaderCell { label: "Progress"; cell-width: 124px; }
        HeaderCell { label: "Size"; cell-width: 138px; }
        HeaderCell { label: "Down"; cell-width: 82px; }
        HeaderCell { label: "Sources"; cell-width: 126px; }
        HeaderCell { label: "Category"; cell-width: 130px; }
    }
}

component TransferRow inherits Rectangle {
    in property <TransferItem> item;
    in property <bool> selected-row;
    callback selected;

    height: 28px;
    background: selected-row ? #dbeafe : #ffffff;
    border-color: selected-row ? #93c5fd : #e5e7eb;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        DataCell { value: item.name; cell-width: 330px; }
        Rectangle {
            width: 82px;
            height: 28px;
            background: transparent;
            RowBadge {
                y: 5px;
                text: item.state;
                fill: item.state == "downloading" ? #dcfce7 : item.state == "error" ? #fee2e2 : #f1f5f9;
                ink: item.state == "downloading" ? #166534 : item.state == "error" ? #991b1b : #334155;
            }
        }
        Rectangle {
            width: 124px;
            height: 28px;
            background: transparent;
            ProgressBar { x: 0px; y: 11px; width: 72px; value: item.progress; fill: #2563eb; }
            DataCell { x: 80px; value: item.progress-text; cell-width: 44px; }
        }
        NumberCell { value: item.size-text; cell-width: 138px; }
        NumberCell { value: item.speed-text; cell-width: 82px; }
        MutedCell { value: item.sources-text; cell-width: 126px; }
        MutedCell { value: item.category; cell-width: 130px; }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.selected(); }
    }
}

component ServerHeader inherits Rectangle {
    height: 26px;
    background: #eef2f7;
    border-color: #cbd5e1;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        HeaderCell { label: "Name"; cell-width: 220px; }
        HeaderCell { label: "Endpoint"; cell-width: 178px; }
        HeaderCell { label: "Status"; cell-width: 86px; }
        HeaderCell { label: "Users"; cell-width: 92px; }
        HeaderCell { label: "Files"; cell-width: 92px; }
        HeaderCell { label: "Ping"; cell-width: 72px; }
        HeaderCell { label: "Priority"; cell-width: 86px; }
        HeaderCell { label: "Fails"; cell-width: 82px; }
    }
}

component ServerRow inherits Rectangle {
    in property <ServerItem> item;
    in property <bool> selected-row;
    callback selected;

    height: 28px;
    background: selected-row ? #dbeafe : item.current ? #eff6ff : #ffffff;
    border-color: selected-row || item.current ? #93c5fd : #e5e7eb;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        DataCell { value: item.name; cell-width: 220px; }
        MutedCell { value: item.endpoint; cell-width: 178px; }
        Rectangle {
            width: 86px;
            height: 28px;
            background: transparent;
            RowBadge {
                y: 5px;
                text: item.status;
                fill: item.status == "connected" ? #dbeafe : item.status == "connecting" ? #fef3c7 : #f1f5f9;
                ink: item.status == "connected" ? #1d4ed8 : item.status == "connecting" ? #92400e : #334155;
            }
        }
        NumberCell { value: item.users-text; cell-width: 92px; }
        NumberCell { value: item.files-text; cell-width: 92px; }
        NumberCell { value: item.ping-text; cell-width: 72px; }
        MutedCell { value: item.priority; cell-width: 86px; }
        NumberCell { value: item.failed-text; cell-width: 82px; }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.selected(); }
    }
}

